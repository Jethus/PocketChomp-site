---
import Button from "./ui/Button.astro";
import ThemeToggle from "./ui/ThemeToggle.astro";
import logoLight from "../assets/svgs/logo-light.svg";
import logoDark from "../assets/svgs/logo-dark.svg";
---

<header class="sticky top-0 z-50 border-b border-border bg-background/85 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" aria-label="PocketChomp home" class="inline-flex items-center">
      <span class="logo-light">
        <img src={logoLight.src} alt="PocketChomp" class="h-12 w-auto sm:h-14" />
      </span>
      <span class="logo-dark">
        <img src={logoDark.src} alt="PocketChomp" class="h-12 w-auto sm:h-14" />
      </span>
    </a>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <Button href="#signup" size="lg" variant="accent">Join the beta</Button>
    </div>
  </div>
</header>

<style>
  .logo-dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .logo-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .logo-dark {
    display: inline-flex;
  }
</style>
