---
/**
 * ClientCard — Portfolio case study card with image, tags, and link.
 *
 * Usage:
 *   <ClientCard
 *     image={reportsImg}
 *     tags="Regulatory / Education"
 *     name="Ontario College of Teachers"
 *     href="/case-studies/oct"
 *   />
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  tags: string;
  name: string;
  href?: string;
  class?: string;
}

const { image, tags, name, href = "#", class: className = "" } = Astro.props;
---

<article class:list={["group", className]}>
  <div
    class="mb-5 overflow-hidden rounded-brutal border-3 border-ink shadow-brutal transition-all duration-300 group-hover:translate-x-0.5 group-hover:translate-y-0.5 group-hover:shadow-brutal-hover"
  >
    <Image
      src={image}
      alt={name}
      width={640}
      height={400}
      class="aspect-16/10 w-full object-cover"
      loading="lazy"
    />
  </div>

  <p
    class="mb-1 font-display text-xs font-bold uppercase tracking-[0.15em] text-ink/50"
  >
    {tags}
  </p>
  <h3 class="mb-2 font-display text-xl font-bold">{name}</h3>
  <div class="mb-3 h-[2px] w-full bg-primary"></div>
  <a
    href={href}
    class="font-display text-sm font-bold text-ink transition-colors duration-200 hover:text-primary"
  >
    Read case study
  </a>
</article>
