---
interface Props {
  columns: [string, string, string];
  rows: [string, string, string][];
  highlightColumn?: number;
  class?: string;
}

const {
  columns,
  rows,
  highlightColumn = 2,
  class: className = "",
} = Astro.props;
---

<div
  class:list={["sudo-table", className]}
  role="table"
  aria-label="Feature comparison"
>
  {/* Headings row */}
  <div class="sudo-table__row sudo-table__row--head" role="row">
    {
      columns.map((col, i) => (
        <strong
          class:list={[
            "sudo-table__cell fs-xs",
            i === highlightColumn && "sudo-table__cell--highlight",
            i === 1 && "sudo-table__cell--deemphasized",
          ]}
          role="columnheader"
        >
          {col}
        </strong>
      ))
    }
  </div>

  {/* Content rows */}
  {
    rows.map((row) => (
      <div class="sudo-table__row" role="row">
        {row.map((cell, i) => (
          <span
            class:list={[
              "sudo-table__cell fs-xs",
              i === 0 && "sudo-table__cell--feature",
              i === highlightColumn && "sudo-table__cell--highlight",
              i === 1 && "sudo-table__cell--deemphasized",
            ]}
            role="cell"
          >
            {cell}
          </span>
        ))}
      </div>
    ))
  }
</div>

<style>
  .sudo-table {
    width: 100%;
    border: 3px solid var(--color-ink, #1a1a1a);
    border-radius: var(--radius-brutal, 12px);
    overflow: hidden;
    box-shadow: var(--shadow-brutal, 4px 4px 0px 0px oklch(0.2 0.02 250));
  }

  .sudo-table__row {
    display: grid;
    grid-template-columns: 0.75fr 1fr 1fr;
    border-bottom: 1px solid var(--color-ink, #1a1a1a);
  }

  .sudo-table__row--head {
    border-bottom-width: 2px;
  }

  .sudo-table__cell {
    padding: 0.875rem 1rem;
    color: var(--color-ink, #1a1a1a);
  }

  /* First column = feature label */
  .sudo-table__cell--feature {
    font-weight: 600;
  }

  /* Highlighted brand column */
  .sudo-table__row--head .sudo-table__cell--highlight {
    background: var(--color-primary, #2e7d32);
    color: var(--color-cream, #fff);
    font-weight: 700;
  }

  .sudo-table__row:not(.sudo-table__row--head) .sudo-table__cell--highlight {
    background: var(--color-primary-light, oklch(0.95 0.04 155));
    color: var(--color-ink, #1a1a1a);
    font-weight: 500;
  }

  /* De-emphasize the middle column */
  .sudo-table__cell--deemphasized {
    opacity: 0.6;
  }

  /* Header text styling */
  .sudo-table__row--head .sudo-table__cell {
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-bottom: 1rem;
  }
</style>
