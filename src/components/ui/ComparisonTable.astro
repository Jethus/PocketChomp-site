---
/**
 * ComparisonTable — Side-by-side feature comparison with an elevated highlight column.
 *
 * Usage:
 *   <ComparisonTable
 *     columns={["Feature", "DIY Website", "Our Sites"]}
 *     highlightColumn={2}
 *     rows={[
 *       ["Custom Design", "Limited templates", "Tailored to your brand"],
 *     ]}
 *   />
 */
interface Props {
  columns: [string, string, string];
  rows: [string, string, string][];
  highlightColumn?: number; // 0-indexed, which column gets the elevated treatment
  class?: string;
}

const {
  columns,
  rows,
  highlightColumn = 2,
  class: className = "",
} = Astro.props;

const colStyles = [
  "bg-primary-light", // Feature column
  "bg-gray-200", // DIY column
  "bg-primary/20", // Highlight column
];

const headerStyles = ["bg-primary-light", "bg-gray-200", "bg-primary/40"];
---

<div class:list={["overflow-x-auto p-4", className]}>
  <div
    class="relative grid min-w-[520px] grid-cols-[1.2fr_1fr_1fr] rounded-brutal border-3 border-ink overflow-hidden bg-ink"
    style="gap: 2px;"
  >
    {/* Highlight Backdrop */}
    <div
      class="absolute inset-y-0 right-0 z-0 w-1/3 bg-primary/20 border-l-3 border-ink shadow-brutal translate-x-[-2px] translate-y-[-8px] rounded-t-brutal pointer-events-none"
      style={`left: calc(100% / 3 * ${highlightColumn}); width: calc(100% / 3);`}
    >
      <div
        class="absolute inset-x-[-3px] top-0 h-full border-x-3 border-ink bg-primary/10 rounded-t-brutal"
      >
      </div>
    </div>

    {/* Header row */}
    {
      columns.map((col, i) => (
        <div
          class:list={[
            "relative z-10 px-6 py-5 font-display font-bold flex items-center",
            headerStyles[i],
            i === highlightColumn && "bg-primary/40 text-ink",
            i === 0 && "text-primary",
            i !== highlightColumn && "text-ink/80",
          ]}
        >
          {col}
        </div>
      ))
    }

    {/* Data rows */}
    {
      rows.map((row, rowIdx) =>
        row.map((cell, colIdx) => (
          <div
            class:list={[
              "relative z-10 px-6 py-4 text-sm flex items-center min-h-16",
              colStyles[colIdx],
              colIdx === highlightColumn
                ? "text-ink font-medium bg-primary/10"
                : "text-ink/60",
            ]}
          >
            {cell}
          </div>
        )),
      )
    }
  </div>
</div>
