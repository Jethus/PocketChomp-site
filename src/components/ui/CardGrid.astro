---
/**
 * CardGrid — 3-column grid of service cards.
 *
 * Each card displays a title, description, and decorative icon on a
 * dark-green background. Accepts an array of items with title, description,
 * and an SVG icon string.
 *
 * Usage:
 *   <CardGrid items={[{ title: "SEO", description: "...", icon: "<svg>...</svg>" }]} />
 */
interface CardItem {
  slug: string;
  title: string;
  description: string;
  icon: string; /* raw SVG markup */
}

interface Props {
  items: CardItem[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<div class:list={["card-grid", className]}>
  {
    items.map((item) => (
      <a href={`/services/${item.slug}`} class="card-grid__card">
        <div class="card-grid__icon" set:html={item.icon} />
        <h3 class="card-grid__title">{item.title}</h3>
        <p class="card-grid__desc">{item.description}</p>
        <span class="card-grid__cta">Explore &rarr;</span>
      </a>
    ))
  }
</div>

<style>
  /* ── Grid layout ─────────────────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2.25rem;
  }

  @media (min-width: 640px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Individual card ─────────────────────────────────────── */
  .card-grid__card {
    background: var(--color-primary-dark);
    border: 3px solid var(--color-ink);
    border-radius: var(--radius-brutal);
    padding: 2rem 1.75rem 3.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: var(--shadow-brutal);
    position: relative;
    z-index: 1;
    justify-content: space-between;
  }

  .card-grid__card:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-brutal-lg);
    z-index: 2;
  }

  /* ── Icon ────────────────────────────────────────────────── */
  .card-grid__icon {
    width: 5rem;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    border: 3px solid var(--color-ink);
    border-radius: 50%;
    padding: 1.25rem;
    color: var(--color-ink);
    flex-shrink: 0;
    box-shadow: 4px 4px 0px 0px var(--color-ink);
    position: absolute;
    bottom: -1.75rem;
    right: -1.75rem;
    transform: rotate(-10deg);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 10;
  }

  .card-grid__card:hover .card-grid__icon {
    transform: rotate(15deg) scale(1.15);
    box-shadow: 6px 6px 0px 0px var(--color-ink);
    background: var(--color-primary-light);
  }

  .card-grid__icon :global(svg) {
    width: 100%;
    height: 100%;
    stroke-width: 2.25px;
  }

  /* ── Typography ──────────────────────────────────────────── */
  .card-grid__title {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-surface);
    --fl: 1;
    margin: 0;
  }

  .card-grid__desc {
    color: oklch(0.85 0.02 155);
    line-height: 1.6;
    --fl: -0.25;
    margin: 0;
  }

  /* ── CTA Button ──────────────────────────────────────────── */
  .card-grid__cta {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    --fl: -0.5;
    transition: all 0.2s ease;
  }

  .card-grid__card:hover .card-grid__cta {
    color: var(--color-primary-light);
  }
</style>
