---
/**
 * Tabs — Inline tab bar with underline active state.
 *
 * Renders a row of text tabs. The active tab gets a bold underline.
 * Pairs with a `data-panel` pattern for content switching (JS below).
 *
 * Usage:
 *   <Tabs
 *     id="services"
 *     tabs={["Web Design", "Accessibility", "SEO"]}
 *     activeIndex={0}
 *   />
 */
interface Props {
  id: string;
  tabs: string[];
  activeIndex?: number;
  class?: string;
}

const { id, tabs, activeIndex = 0, class: className = "" } = Astro.props;
---

<div
  class:list={[
    "flex flex-wrap justify-center gap-x-6 gap-y-2 border-b border-ink/20 pb-4",
    className,
  ]}
  data-tabs={id}
>
  {
    tabs.map((label, i) => (
      <button
        class:list={[
          "tab-trigger whitespace-nowrap font-display text-sm font-bold transition-all duration-200 hover:text-ink",
          i === activeIndex
            ? "border-b-2 border-ink text-ink"
            : "text-ink/50",
        ]}
        data-tab-index={i}
        data-tab-group={id}
        aria-selected={i === activeIndex ? "true" : "false"}
        role="tab"
      >
        {label}
      </button>
    ))
  }
</div>

<script is:inline>
  document.querySelectorAll("[data-tabs]").forEach((tabBar) => {
    const group = tabBar.dataset.tabs;
    const triggers = tabBar.querySelectorAll(".tab-trigger");
    const panels = document.querySelectorAll(`[data-tab-panel-group="${group}"]`);

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const index = trigger.dataset.tabIndex;

        // Update tabs
        triggers.forEach((t) => {
          t.classList.remove("border-b-2", "border-ink", "text-ink");
          t.classList.add("text-ink/50");
          t.setAttribute("aria-selected", "false");
        });
        trigger.classList.remove("text-ink/50");
        trigger.classList.add("border-b-2", "border-ink", "text-ink");
        trigger.setAttribute("aria-selected", "true");

        // Show matching panel
        panels.forEach((p) => p.setAttribute("hidden", ""));
        const target = document.querySelector(
          `[data-tab-panel-group="${group}"][data-tab-panel-index="${index}"]`
        );
        if (target) target.removeAttribute("hidden");
      });
    });
  });
</script>
