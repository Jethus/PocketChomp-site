---
/**
 * PricingCard — Lump Sum or Monthly pricing card.
 *
 * Usage:
 *   <PricingCard
 *     variant="lump"
 *     title="Lump Sum"
 *     price="$3800"
 *     priceNote="+$25/mo Hosting"
 *     features={[
 *       { text: "Design And Development", included: true },
 *       { text: "Lifetime Updates", included: false },
 *     ]}
 *     ctaHref="/contact"
 *     ctaText="Get Started"
 *   />
 */
import Button from "./Button.astro";

interface Feature {
  text: string;
  included: boolean;
}

interface Props {
  variant: "lump" | "monthly";
  title: string;
  price: string;
  priceNote?: string;
  features: Feature[];
  ctaHref?: string;
  ctaText?: string;
  class?: string;
}

const {
  variant,
  title,
  price,
  priceNote,
  features,
  ctaHref = "/contact",
  ctaText = "Get Started",
  class: className = "",
} = Astro.props;

const isMonthly = variant === "monthly";
---

<div
  class:list={[
    "flex flex-col rounded-brutal border-3 border-ink p-8 md:p-10",
    isMonthly
      ? "bg-ink text-surface shadow-brutal-lg"
      : "bg-surface text-ink shadow-brutal",
    className,
  ]}
>
  {/* Title */}
  <h3
    class="mb-8 font-display text-2xl font-bold uppercase tracking-wider md:text-3xl"
  >
    {title}
  </h3>

  {/* Feature list */}
  <ul class="mb-8 flex-1 space-y-4">
    {
      features.map((feature) => (
        <li class="flex items-center justify-between gap-4">
          <span
            class:list={[
              "text-sm md:text-base",
              !feature.included && (isMonthly ? "opacity-50" : "opacity-40"),
            ]}
          >
            {feature.text}
          </span>
          {feature.included ? (
            <span class:list={["shrink-0 text-lg", isMonthly ? "text-primary" : "text-primary"]}>
              ✓
            </span>
          ) : (
            <span class="shrink-0 text-lg opacity-40">⊘</span>
          )}
        </li>
      ))
    }
  </ul>

  {/* Price */}
  <div class="mb-6">
    <span class="font-display text-5xl font-bold md:text-6xl">{price}</span>
    {priceNote && (
      <span
        class:list={[
          "ml-2 text-sm",
          isMonthly ? "text-surface/60" : "text-ink/50",
        ]}
      >
        {priceNote}
      </span>
    )}
  </div>

  {/* CTA */}
  {isMonthly ? (
    <a
      href={ctaHref}
      class="inline-flex items-center justify-center rounded-pill border-3 border-primary bg-primary px-8 py-3 font-display font-bold text-ink shadow-brutal transition-all duration-200 hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-brutal-hover"
    >
      {ctaText}
    </a>
  ) : (
    <a
      href={ctaHref}
      class="inline-flex items-center justify-center rounded-pill border-3 border-primary bg-primary px-8 py-3 font-display font-bold text-surface shadow-brutal transition-all duration-200 hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-brutal-hover"
    >
      {ctaText}
    </a>
  )}
</div>
