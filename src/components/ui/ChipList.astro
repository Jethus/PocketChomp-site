---
interface Props {
  items: string[];
  tone?: string;
  class?: string;
}

const { items, tone = "default", class: className = "" } = Astro.props;

// Ionicons-style icons keyed by chip text (lowercase match)
const chipIcons: Record<string, string> = {
  "no sign-up required": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><path d="M336 176h40a40 40 0 0 1 0 80H336"/><path d="M304 176H256"/><circle cx="296" cy="216" r="8" fill="currentColor" stroke="none"/><rect x="48" y="112" width="416" height="288" rx="48" ry="48"/></svg>`,
  "100% on-device": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><rect x="128" y="48" width="256" height="416" rx="40" ry="40"/><line x1="256" y1="400" x2="256" y2="400" stroke-linecap="round" stroke-width="48"/></svg>`,
  "0 ads": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><circle cx="256" cy="256" r="208"/><line x1="96" y1="96" x2="416" y2="416"/></svg>`,
  "premium feel": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><path d="M480 208H308L256 48l-52 160H32l140 96-54 160 138-100 138 100-54-160z"/></svg>`,
  "your data": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="256" cy="160" rx="192" ry="80"/><path d="M64 256c0 44.18 85.96 80 192 80s192-35.82 192-80"/><path d="M64 352c0 44.18 85.96 80 192 80s192-35.82 192-80"/><path d="M64 160v192"/><path d="M448 160v192"/></svg>`,
  "your choice": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><path d="M256 48l32 96h96l-80 56 32 96-80-56-80 56 32-96-80-56h96z"/><path d="M256 320v144"/><path d="M192 464h128"/></svg>`,
  "canadian products": `<svg viewBox="-1953 -2031 3906 4061" fill="currentColor"><path d="m-90 2030 45-863a95 95 0 0 0-111-98l-859 151 116-320a65 65 0 0 0-20-73l-941-762 212-99a65 65 0 0 0 34-79l-186-572 542 115a65 65 0 0 0 73-38l105-247 423 454a65 65 0 0 0 111-57l-204-1052 327 189a65 65 0 0 0 91-27l332-652 332 652a65 65 0 0 0 91 27l327-189-204 1052a65 65 0 0 0 111 57l423-454 105 247a65 65 0 0 0 73 38l542-115-186 572a65 65 0 0 0 34 79l212 99-941 762a65 65 0 0 0-20 73l116 320-859-151a95 95 0 0 0-111 98l45 863z"/></svg>`,
  "local groceries": `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="36" stroke-linecap="round" stroke-linejoin="round"><path d="M80 176l32 240h288l32-240z"/><path d="M160 176a96 96 0 0 1 192 0"/></svg>`,
};

const fallbackIcon = `<svg viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="48" stroke-linecap="round" stroke-linejoin="round"><polyline points="96 272 208 368 416 144"/></svg>`;
---

<ul class:list={["flex flex-wrap gap-3", className]}>
  {
    items.map((item) => {
      const icon = chipIcons[item.toLowerCase()] ?? fallbackIcon;
      return (
        <li class:list={[
          "chip",
          tone === "canadian" ? "chip--canadian" : "chip--default",
        ]}>
          <span class="chip__icon" set:html={icon} />
          {item}
        </li>
      );
    })
  }
</ul>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 0.45rem 0.9rem 0.45rem 0.6rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--foreground);
    box-shadow: var(--shadow-elevated);
  }

  .chip__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: var(--primary);
  }

  .chip--canadian .chip__icon {
    color: var(--accent);
  }

  .chip__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
