---
/**
 * Button primitive for marketing CTAs.
 *
 * Supported variants:
 * - solid
 * - outline
 * - ghost
 *
 * Legacy aliases:
 * - primary -> solid
 * - secondary -> outline
 */
interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  href: string;
  variant?: "solid" | "outline" | "ghost" | "accent" | "primary" | "secondary";
  size?: "sm" | "md" | "lg" | "base";
  class?: string;
}

const {
  href,
  variant = "solid",
  size = "md",
  class: className = "",
  ...rest
} = Astro.props as Props;

const normalizedVariant =
  variant === "primary" ? "solid" : variant === "secondary" ? "outline" : (variant ?? "solid");

const normalizedSize = size === "base" ? "md" : size;

const variants = {
  solid:
    "border-transparent bg-primary text-primary-foreground shadow-[var(--shadow-elevated)] hover:-translate-y-0.5 hover:bg-primary/92",
  outline:
    "border-border bg-surface text-foreground hover:-translate-y-0.5 hover:bg-muted/80",
  ghost:
    "border-transparent bg-transparent text-foreground hover:-translate-y-0.5 hover:bg-muted/70",
  accent:
    "border-transparent bg-accent text-accent-foreground shadow-[var(--shadow-elevated)] hover:-translate-y-0.5 hover:bg-accent/90",
} as const;

const sizes = {
  sm: "h-10 px-4 text-[0.8rem]",
  md: "h-11 px-5 text-[0.86rem]",
  lg: "h-14 px-8 text-[1rem]",
} as const;

const rel = rest.target === "_blank"
  ? [rest.rel, "noopener", "noreferrer"].filter(Boolean).join(" ")
  : rest.rel;
---

<a
  href={href}
  {...rest}
  rel={rel}
  class:list={[
    "inline-flex cursor-pointer items-center justify-center gap-2 rounded-full border font-heading font-black uppercase transition duration-200 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/30 focus-visible:ring-offset-2 focus-visible:ring-offset-background",
    variants[normalizedVariant],
    sizes[normalizedSize],
    className,
  ]}
>
  <slot />
</a>
