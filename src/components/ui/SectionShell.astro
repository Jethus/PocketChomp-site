---
interface Props extends astroHTML.JSX.HTMLAttributes {
  as?: "section" | "div" | "article";
  innerClass?: string;
}

const {
  as: Tag = "section",
  innerClass = "",
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<Tag {...rest} class:list={["py-16 sm:py-20 lg:py-24", className]}>
  <div class:list={["mx-auto w-full max-w-7xl px-6", innerClass]}>
    <slot />
  </div>
</Tag>
