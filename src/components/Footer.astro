---
import logoWhite from "../assets/svgs/logo-white.svg";
const today = new Date();
---

<footer class="bg-ink text-surface">
  <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-4">
      <div class="md:col-span-1">
        <a href="/" class="inline-block">
          <img src={logoWhite.src} alt="Pixelboost" class="h-7 w-auto" />
        </a>
        <p class="mt-4 max-w-xs leading-relaxed text-surface/60 fs-xs">
          Whitby-based web development and design agency creating
          high-performance websites for small businesses.
        </p>
      </div>

      <div>
        <h4 class="mb-4 font-display font-bold uppercase tracking-widest text-accent fs-xs">
          Services
        </h4>
        <ul class="space-y-2 fs-xs">
          <li><a href="/services" class="text-surface/70 transition-colors duration-200 hover:text-surface">Web Development</a></li>
          <li><a href="/services" class="text-surface/70 transition-colors duration-200 hover:text-surface">Web Design</a></li>
          <li><a href="/services" class="text-surface/70 transition-colors duration-200 hover:text-surface">Branding</a></li>
          <li><a href="/services" class="text-surface/70 transition-colors duration-200 hover:text-surface">Print Design</a></li>
          <li><a href="/services" class="text-surface/70 transition-colors duration-200 hover:text-surface">SEO</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-display font-bold uppercase tracking-widest text-accent fs-xs">
          Agency
        </h4>
        <ul class="space-y-2 fs-xs">
          <li><a href="/about" class="text-surface/70 transition-colors duration-200 hover:text-surface">About Us</a></li>
          <li><a href="#portfolio" class="text-surface/70 transition-colors duration-200 hover:text-surface">Case Studies</a></li>
          <li><a href="/contact" class="text-surface/70 transition-colors duration-200 hover:text-surface">Contact Us</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-display font-bold uppercase tracking-widest text-accent fs-xs">
          Get in Touch
        </h4>
        <ul class="space-y-2 fs-xs">
          <li><a href="tel:+12896342593" class="text-surface/70 transition-colors duration-200 hover:text-surface">(289) 634-2593</a></li>
          <li><a href="mailto:hi@pixelboost.ca" class="text-surface/70 transition-colors duration-200 hover:text-surface">hi@pixelboost.ca</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-surface/10 pt-6 text-center text-surface/40 fs-xs">
      &copy; {today.getFullYear()} Pixelboost. All rights reserved.
    </div>
  </div>
</footer>
