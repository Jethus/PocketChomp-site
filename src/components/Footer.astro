---
import { getEntry } from "astro:content";
import logoLight from "../assets/svgs/logo-light.svg";
import logoDark from "../assets/svgs/logo-dark.svg";

const footerEntry = await getEntry("landingFooter", "footer");

if (!footerEntry) {
  throw new Error("Could not find PocketChomp footer content");
}

const { tagline, links } = footerEntry.data;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-strong">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 px-6 py-10 md:flex-row md:items-end md:justify-between">
    <div class="space-y-4">
      <a href="/" aria-label="PocketChomp home" class="inline-flex items-center">
        <span class="footer-logo-light">
          <img src={logoLight.src} alt="PocketChomp" class="h-12 w-auto sm:h-14" />
        </span>
        <span class="footer-logo-dark">
          <img src={logoDark.src} alt="PocketChomp" class="h-12 w-auto sm:h-14" />
        </span>
      </a>

      <p class="text-sm text-muted-foreground">
        &copy; {currentYear} PocketChomp. {tagline}
      </p>
    </div>

    <nav aria-label="Footer" class="flex flex-wrap gap-6 text-sm text-muted-foreground">
      {
        links.map((link) => (
          <a href={link.href} class="transition hover:text-foreground">
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .footer-logo-dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .footer-logo-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .footer-logo-dark {
    display: inline-flex;
  }
</style>
