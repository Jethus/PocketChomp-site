---
import ClientCard from "./ui/ClientCard.astro";
import { getCollection, getEntry } from "astro:content";

const portfolioLayout = await getEntry('landingPortfolio', 'portfolio');
if (!portfolioLayout) throw new Error("Could not find portfolio section content");
const { eyebrow, headline } = portfolioLayout.data;

const clientsDocs = await getCollection("portfolio");
const clients = clientsDocs.map((doc) => ({
  name: doc.id,
  tags: doc.data.tags,
  image: doc.data.image,
}));
---

<section class="border-b-3 border-ink bg-primary-light" id="portfolio">
  <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
    <div class="mb-16 text-center">
      <p class="mb-2 font-display font-bold uppercase tracking-[0.2em] text-accent fs-xs">
        {eyebrow}
      </p>
      <h2 class="font-display font-bold">
        {headline}
      </h2>
    </div>

    <div class="grid gap-x-12 gap-y-16 md:grid-cols-2">
      {
        clients.map((client, i) => (
          <ClientCard
            image={client.image}
            tags={client.tags}
            name={client.name}
            class={i % 2 !== 0 ? "md:mt-24" : ""}
          />
        ))
      }
    </div>
  </div>
</section>
