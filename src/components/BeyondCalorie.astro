---
import { getEntry } from "astro:content";
import SectionShell from "./ui/SectionShell.astro";

const beyondEntry = await getEntry("landingBeyondCalorie", "beyond-calorie");

if (!beyondEntry) {
  throw new Error("Could not find PocketChomp beyond-calorie content");
}

const {
  headline,
  description,
  nutrients,
  statLabel,
  progressBars,
  statMetricLabel,
  statValue,
} = beyondEntry.data;

const getProgressWidthClass = (percentage: number) => {
  const widths = {
    0: "w-0",
    5: "w-[5%]",
    10: "w-[10%]",
    15: "w-[15%]",
    20: "w-[20%]",
    25: "w-1/4",
    30: "w-[30%]",
    35: "w-[35%]",
    40: "w-2/5",
    45: "w-[45%]",
    50: "w-1/2",
    55: "w-[55%]",
    60: "w-3/5",
    65: "w-[65%]",
    70: "w-[70%]",
    75: "w-3/4",
    80: "w-4/5",
    85: "w-[85%]",
    90: "w-[90%]",
    95: "w-[95%]",
    100: "w-full",
  } as const;

  const rounded = Math.min(100, Math.max(0, Math.round(percentage / 5) * 5)) as keyof typeof widths;
  return widths[rounded];
};
---

<SectionShell
  class="pt-8"
  innerClass="overflow-hidden rounded-[2.5rem] bg-accent px-6 py-10 text-accent-foreground shadow-[var(--shadow-elevated-lg)] md:px-10 md:py-14 lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(18rem,1fr)] lg:items-center lg:gap-14"
>
  <div>
    <h2 class="max-w-[8ch] text-5xl uppercase leading-[0.9] md:text-6xl lg:text-7xl">
      {headline}
    </h2>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-black/80">
      {description}
    </p>

    <ul class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        nutrients.map((nutrient) => (
          <li class="rounded-[1.5rem] border border-black/18 bg-black/6 px-5 py-4 font-heading text-xl font-black uppercase">
            {nutrient}
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-10 rounded-[2rem] bg-black/92 p-6 text-white shadow-[var(--shadow-elevated)] lg:mt-0">
    <p class="text-sm uppercase tracking-[0.22em] text-white/62">{statLabel}</p>

    <div class="mt-6 space-y-5">
      {
        progressBars.map((bar) => (
          <div>
            <div class="mb-2 flex items-center justify-between text-sm uppercase tracking-[0.18em] text-white/60">
              <span>{bar.label}</span>
              <span>{bar.percentage}%</span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-white/12">
              <div
                class:list={[
                  "h-full rounded-full",
                  getProgressWidthClass(bar.percentage),
                  bar.fill === "accent" ? "bg-accent" : "bg-primary",
                ]}
              ></div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-8 inline-flex items-center gap-4 rounded-[1.5rem] bg-white px-6 py-4 text-black shadow-[var(--shadow-elevated)]">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-xl font-heading font-black text-primary-foreground">
        &#9889;
      </span>
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/55">{statMetricLabel}</p>
        <p class="font-heading text-4xl font-black uppercase">{statValue}</p>
      </div>
    </div>
  </div>
</SectionShell>
