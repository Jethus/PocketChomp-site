---
import { getEntry } from "astro:content";
import Button from "./ui/Button.astro";
import SectionShell from "./ui/SectionShell.astro";
import heroShot from "../assets/png/hero-app-shot.png";
import androidFrameDark from "../assets/png/android-frame-dark.png";
import androidFrameLight from "../assets/png/android-frame-light.png";

const heroEntry = await getEntry("landingHero", "hero");

if (!heroEntry) {
  throw new Error("Could not find PocketChomp hero content");
}

const {
  headline,
  accent,
  description,
  primaryCtaText,
  primaryCtaLink,
  secondaryCtaText,
  secondaryCtaLink,
  collageCards,
} = heroEntry.data;

const [topLeftCard, bottomLeftCard, topRightCard, bottomRightCard] = collageCards;
---

<section id="hero" class="overflow-x-clip border-b border-border hero-section">
  <SectionShell
    class="hero-shell"
    innerClass="max-w-[90rem] grid items-start gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-12"
  >
    <div class="pt-2">
      <h1 class="text-5xl uppercase leading-[1.1] text-foreground sm:text-6xl md:text-7xl lg:text-[5.35rem]">
        {headline}
        <span class="block text-accent">{accent}</span>
      </h1>

      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        {description}
      </p>

      <div class="mt-7 flex flex-wrap gap-4">
        <Button href={primaryCtaLink} variant="outline" size="lg" class="hero-cta hero-cta--primary">
          {primaryCtaText}
        </Button>
        <Button href={secondaryCtaLink} variant="outline" size="lg" class="hero-cta">
          {secondaryCtaText}
        </Button>
      </div>
    </div>

    <div class="hero-grid" aria-hidden="true">
      <article class="hero-panel hero-panel--support hero-panel--tl">
        <span class="hero-panel__eyebrow">Private</span>
        <p class="hero-panel__title">{topLeftCard.title}</p>
        {topLeftCard.body && <p class="hero-panel__body">{topLeftCard.body}</p>}
      </article>

      <article class="hero-panel hero-panel--support hero-panel--bl">
        <p class="hero-panel__title hero-panel__title--compact">{bottomLeftCard.title}</p>
        {bottomLeftCard.body && <p class="hero-panel__body">{bottomLeftCard.body}</p>}
      </article>

      <div class="hero-panel hero-panel--phone hero-panel--center">
        <img
          src={heroShot.src}
          alt="PocketChomp app preview inside an Android device frame"
          class="hero-phone__screen"
        />
        <img src={androidFrameLight.src} alt="" class="hero-frame hero-frame--light" />
        <img src={androidFrameDark.src} alt="" class="hero-frame hero-frame--dark" />
      </div>

      <article class="hero-panel hero-panel--meta hero-panel--tr">
        <div class="hero-meta">
          <div class="hero-meta__mark">
            <span class="hero-meta__dot"></span>
          </div>
          <div>
            <p class="hero-panel__title">{topRightCard.title}</p>
            {topRightCard.body && <p class="hero-panel__body">{topRightCard.body}</p>}
          </div>
        </div>
      </article>

      <article class="hero-panel hero-panel--support hero-panel--br">
        <p class="hero-panel__title hero-panel__title--compact">Track your food</p>
        <p class="hero-panel__body">fast, local-first, no clutter</p>
      </article>

      <article class="hero-panel hero-panel--mini hero-panel--bc">
        <span class="hero-mini__dot"></span>
        <span class="hero-mini__label">on-device by default</span>
      </article>
    </div>
  </SectionShell>
</section>

<style>
  .hero-cta {
    min-width: 12rem;
  }

  .hero-cta--primary {
    background: var(--accent);
    color: var(--accent-foreground);
    border-color: transparent;
  }

  /* Grid fills its column, height derived from aspect-ratio */
  .hero-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows: repeat(8, 1fr);
    gap: 1.25rem;
    width: 100%;
    aspect-ratio: 1 / 1.25;
  }

  .hero-panel {
    border: 1px solid var(--border);
    border-radius: 1.6rem;
    background: var(--surface);
    box-shadow: var(--shadow-elevated);
    overflow: hidden;
  }

  .hero-panel--support,
  .hero-panel--meta {
    padding: 1rem 0.95rem;
  }

  .hero-panel--support {
    background: color-mix(in oklab, var(--primary) 26%, var(--surface));
  }

  /* cols 1-3: left panels, cols 4-7: phone, cols 8-10: right panels */
  .hero-panel--tl {
    grid-column: 1 / span 3;
    grid-row: 1 / span 4;
  }

  .hero-panel--bl {
    grid-column: 1 / span 3;
    grid-row: 5 / span 3;
  }

  .hero-panel--center {
    position: relative;
    grid-column: 4 / span 4;
    grid-row: 1 / span 5;
    display: flex;
    align-items: stretch;
    justify-content: center;
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    overflow: visible;
  }

  .hero-panel--bc {
    grid-column: 4 / span 4;
    grid-row: 6 / span 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    border-radius: 1.6rem;
    background: color-mix(in oklab, var(--surface) 86%, transparent);
    padding-inline: 0.85rem;
  }

  .hero-panel--tr {
    grid-column: 8 / span 3;
    grid-row: 1 / span 4;
  }

  .hero-panel--br {
    grid-column: 8 / span 3;
    grid-row: 5 / span 3;
  }

  .hero-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 2;
    pointer-events: none;
  }

  .hero-frame--dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .hero-frame--light {
    display: none;
  }

  :global(html[data-theme="dark"]) .hero-frame--dark {
    display: block;
  }

  .hero-phone__screen {
    position: absolute;
    inset: 3.5% 6% 3.5% 6%;
    width: 88%;
    height: 93%;
    border-radius: 1.6rem;
    object-fit: cover;
    object-position: top;
    z-index: 1;
  }

  .hero-panel__eyebrow {
    display: inline-flex;
    align-items: center;
    margin-bottom: 0.7rem;
    font-family: var(--font-heading);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .hero-panel__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(0.65rem, 1.8cqi, 1rem);
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    color: var(--foreground);
  }

  .hero-panel__title--compact {
    font-size: clamp(0.6rem, 1.6cqi, 0.9rem);
  }

  .hero-panel__body {
    margin: 0.55rem 0 0;
    font-size: clamp(0.55rem, 1.4cqi, 0.78rem);
    line-height: 1.4;
    text-transform: lowercase;
    color: var(--muted-foreground);
  }

  /* Make panels container-aware so text scales with panel size */
  .hero-panel--tl,
  .hero-panel--bl,
  .hero-panel--tr,
  .hero-panel--br {
    container-type: inline-size;
  }

  .hero-meta {
    display: grid;
    align-content: space-between;
    justify-items: start;
    height: 100%;
  }

  .hero-meta__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(2rem, 5cqi, 3.2rem);
    height: clamp(2rem, 5cqi, 3.2rem);
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 24%, var(--surface));
    border: 1px solid color-mix(in oklab, var(--accent) 55%, transparent);
  }

  .hero-meta__dot {
    width: clamp(0.6rem, 1.6cqi, 1rem);
    height: clamp(0.6rem, 1.6cqi, 1rem);
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 0.32rem color-mix(in oklab, var(--accent) 22%, transparent);
  }

  .hero-mini__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--primary);
  }

  .hero-mini__label {
    font-family: var(--font-heading);
    font-size: 0.55rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  :global(html[data-theme="dark"]) .hero-panel:not(.hero-panel--center) {
    background: color-mix(in oklab, var(--surface) 92%, black);
  }

  :global(html[data-theme="dark"]) .hero-panel--support {
    background: color-mix(in oklab, var(--primary) 34%, var(--surface));
  }

  :global(html[data-theme="dark"]) .hero-panel--bc {
    background: color-mix(in oklab, var(--surface) 90%, black);
  }

  /* Below lg: grid goes full width, stack is centered, cap to readable size */
  @media (max-width: 64rem) {
    .hero-grid {
      max-width: 36rem;
      margin-inline: auto;
    }
  }
</style>
