---
import { getEntry } from "astro:content";
import Button from "./ui/Button.astro";

const heroDoc = await getEntry('landingHero', 'hero');
if (!heroDoc) throw new Error("Could find hero content");
const { eyebrow, headline, description, cta1Text, cta1Link, cta2Text, cta2Link } = heroDoc.data;
---

<section class="bg-primary-light border-b-3 border-ink">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center gap-10 px-6 py-20 md:flex-row md:gap-16 md:py-28 lg:py-32"
  >
    <!-- Text content -->
    <div class="flex max-w-2xl flex-col items-start gap-6 md:flex-1">
      <p class="font-display font-bold uppercase tracking-widest text-accent fs-xs">
        {eyebrow}
      </p>

      <h1 class="font-display font-bold leading-tight" set:html={headline}></h1>

      <p class="max-w-lg leading-relaxed text-ink/70" set:html={description}></p>

      <div class="flex flex-wrap gap-4 pt-2">
        <Button href={cta1Link}>{cta1Text}</Button>
        <Button href={cta2Link} variant="secondary">{cta2Text}</Button>
      </div>
    </div>

    <!-- Decorative grid -->
    <div
      class="relative hidden aspect-square w-full max-w-md md:flex md:flex-1 md:items-center md:justify-center"
    >
      <div class="grid h-72 w-72 grid-cols-3 grid-rows-3 gap-3 lg:h-80 lg:w-80">
        <div class="rounded-brutal border-3 border-ink bg-surface shadow-brutal"></div>
        <div class="col-span-2 rounded-brutal border-3 border-ink bg-primary/20 shadow-brutal"></div>
        <div class="col-span-2 rounded-brutal border-3 border-ink bg-primary-light shadow-brutal"></div>
        <div class="rounded-brutal border-3 border-ink bg-primary/40 shadow-brutal"></div>
        <div class="rounded-brutal border-3 border-ink bg-primary shadow-brutal"></div>
        <div class="rounded-brutal border-3 border-ink bg-accent/30 shadow-brutal"></div>
        <div class="rounded-brutal border-3 border-ink bg-ink shadow-brutal"></div>
      </div>
    </div>
  </div>
</section>
