---
import { getEntry } from "astro:content";
import Button from "./ui/Button.astro";
import { Image } from "astro:assets";
import heroImg from "../assets/png/hero.png";

const heroDoc = await getEntry("landingHero", "hero");
if (!heroDoc) throw new Error("Could find hero content");
const {
  eyebrow,
  headline,
  description,
  cta1Text,
  cta1Link,
  cta2Text,
  cta2Link,
} = heroDoc.data;
---

<section class="bg-primary-light border-b-3 border-ink">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center gap-10 px-6 py-20 md:flex-row md:gap-16 md:py-28 lg:py-32"
  >
    <!-- Text content -->
    <div class="flex max-w-2xl flex-col items-start gap-6 md:flex-1">
      <p
        class="font-display font-bold uppercase tracking-widest text-accent fs-xs"
      >
        {eyebrow}
      </p>

      <h1 class="font-display font-black leading-tight" set:html={headline} />

      <p class="max-w-lg leading-relaxed text-ink/70" set:html={description} />

      <div class="flex flex-wrap gap-4 pt-2">
        <Button href={cta1Link}>{cta1Text}</Button>
        <Button href={cta2Link} variant="secondary">{cta2Text}</Button>
      </div>
    </div>

    <!-- Mockup Image with Mac Window & Hover Scroll -->
    <div
      class="relative hidden w-full md:flex md:flex-col md:flex-1 rounded-brutal border-3 border-ink shadow-brutal overflow-hidden group bg-surface h-128"
    >
      <!-- Mac Window Bar -->
      <div
        class="flex items-center gap-2 border-b-3 border-ink bg-primary-light px-4 py-3"
      >
        <div class="h-3 w-3 rounded-full border-2 border-ink bg-red-400"></div>
        <div class="h-3 w-3 rounded-full border-2 border-ink bg-yellow-400">
        </div>
        <div class="h-3 w-3 rounded-full border-2 border-ink bg-green-400">
        </div>
      </div>
      <!-- Mockup Viewer -->
      <div class="relative flex-1 w-full overflow-hidden bg-ink/5">
        <Image
          src={heroImg}
          alt="Pixelboost custom website design mockup"
          width={800}
          class="absolute inset-0 w-full h-[300%] max-h-none object-cover object-top transition-all duration-[8000ms] ease-linear group-hover:object-bottom"
          priority
        />
      </div>
    </div>
  </div>
</section>
