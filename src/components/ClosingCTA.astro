---
import { getEntry } from "astro:content";
import SectionShell from "./ui/SectionShell.astro";
import SignupForm from "./ui/SignupForm.astro";

const ctaEntry = await getEntry("landingSignupCta", "signup-cta");

if (!ctaEntry) {
  throw new Error("Could not find PocketChomp signup CTA content");
}

const { headline, description, inputPlaceholder, buttonText, note } = ctaEntry.data;
---

<SectionShell class="pb-10">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,36rem)] lg:items-center">
    <div>
      <h2 class="text-4xl uppercase leading-[0.92] text-foreground md:text-5xl lg:text-6xl">
        {headline}
      </h2>
      <p class="mt-3 max-w-xl text-lg leading-relaxed text-muted-foreground">
        {description}
      </p>
    </div>

    <div>
      <SignupForm placeholder={inputPlaceholder} buttonText={buttonText} />
      <p class="mt-4 text-sm leading-relaxed text-muted-foreground">{note}</p>
    </div>
  </div>
</SectionShell>
