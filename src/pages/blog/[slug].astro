---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SignupForm from "../../components/ui/SignupForm.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString("en-CA", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const tags = post.data.tags ?? [];

// Read time
const words = (post.body ?? "").trim().split(/\s+/).length;
const readTime = `${Math.max(1, Math.ceil(words / 200))} min read`;

// Tag styles
const tagStyles: Record<string, string> = {
  Devlog: "border-border text-foreground bg-surface",
  ADR: "border-accent/40 text-accent bg-accent/8",
  Prompting: "border-primary/40 text-primary bg-primary/10",
  Debugging: "border-yellow-400/30 text-yellow-300 bg-yellow-400/6",
  Philosophy: "border-primary/35 text-primary-foreground/80 bg-primary/15",
};
const tagNeutral = "border-border text-muted-foreground bg-surface";

function tagClass(tag: string): string {
  return `inline-flex items-center rounded-full border px-2.5 py-0.5 font-heading text-[0.62rem] font-black uppercase tracking-[0.08em] ${tagStyles[tag] ?? tagNeutral}`;
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <Header />
  <main>

    <!-- Article header -->
    <header class="border-b border-border">
      <div class="mx-auto max-w-3xl px-6 py-16 md:py-20">
        <a
          href="/blog"
          class="mb-8 inline-flex items-center gap-2 font-mono text-[0.7rem] tracking-[0.05em] text-muted-foreground transition-colors hover:text-accent"
        >
          ← All posts
        </a>

        <!-- Meta row -->
        <div class="mb-5 flex flex-wrap items-center gap-3 font-mono text-[0.7rem] text-muted-foreground">
          {tags.map(tag => (
            <span class={tagClass(tag)}>{tag}</span>
          ))}
          <span>{formattedDate}</span>
          <span>·</span>
          <span>{readTime}</span>
        </div>

        <h1 class="font-heading font-black uppercase leading-[0.93] tracking-tight">
          {post.data.title}
        </h1>
        <p class="mt-5 max-w-[62ch] text-lg leading-relaxed text-muted-foreground">
          {post.data.description}
        </p>

        <!-- Author row -->
        <div class="mt-8 flex items-center gap-3 border-t border-border pt-5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-accent font-heading text-sm font-black text-accent-foreground">
            JT
          </div>
          <div>
            <p class="text-sm font-bold leading-tight text-foreground">Josh</p>
            <p class="font-mono text-[0.68rem] text-muted-foreground">@jethus · solo founder</p>
          </div>
          <div class="ml-auto flex gap-2">
            <!-- Copy link -->
            <button
              aria-label="Copy link"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border text-muted-foreground transition-colors hover:border-accent hover:text-accent"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </button>
            <!-- Share -->
            <button
              aria-label="Share"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border text-muted-foreground transition-colors hover:border-accent hover:text-accent"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                <path d="M16 6l-4-4-4 4M12 2v13"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Prose body -->
    <div class="border-b border-border">
      <div class="mx-auto max-w-3xl px-6 py-14">
        <article class="post-body">
          <Content />
        </article>

        <!-- Post nav -->
        {(prev || next) && (
          <nav class="post-nav mt-16 grid gap-4 sm:grid-cols-2" aria-label="Post navigation">
            {prev ? (
              <a href={`/blog/${prev.id}`} class="post-nav-link">
                <span class="post-nav-dir">← Older post</span>
                <span class="post-nav-title">{prev.data.title}</span>
              </a>
            ) : <div />}
            {next ? (
              <a href={`/blog/${next.id}`} class="post-nav-link text-right">
                <span class="post-nav-dir">Newer post →</span>
                <span class="post-nav-title">{next.data.title}</span>
              </a>
            ) : <div />}
          </nav>
        )}

        <!-- Newsletter strip -->
        <div class="newsletter-strip mt-16 rounded-[1.5rem] border border-border bg-surface p-8 md:p-10">
          <h3 class="font-heading font-black uppercase tracking-tight">Field notes in your inbox.</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            One post per build. No spam, no tracking pixels. Unsubscribe any time.
          </p>
          <div class="mt-5">
            <SignupForm placeholder="you@example.com" buttonText="Subscribe" />
          </div>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Post body prose ───────────────────────────────────────── */
  .post-body {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    line-height: 1.7;
    color: var(--color-foreground);
  }

  .post-body :global(p) {
    margin: 0 0 1.3em;
    color: var(--color-muted-foreground);
  }

  .post-body :global(h2) {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.35rem, 3vw, 2rem);
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 1;
    margin: 3.5rem 0 1.25rem;
    color: var(--color-foreground);
  }

  .post-body :global(h3) {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    text-transform: uppercase;
    letter-spacing: -0.005em;
    margin: 2.5rem 0 0.875rem;
    color: var(--color-foreground);
  }

  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(h6) {
    font-family: var(--font-heading);
    font-weight: 900;
    margin: 2rem 0 0.75rem;
    color: var(--color-foreground);
  }

  .post-body :global(a) {
    color: var(--color-accent);
    border-bottom: 1px solid color-mix(in oklch, var(--color-accent), transparent 60%);
    transition: border-color 0.15s;
  }
  .post-body :global(a:hover) {
    border-color: var(--color-accent);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.3em;
  }
  .post-body :global(li) {
    margin: 0 0 0.5em;
    color: var(--color-muted-foreground);
  }
  .post-body :global(ul li::marker) {
    color: var(--color-accent);
  }
  .post-body :global(ol) {
    list-style-type: decimal;
  }

  .post-body :global(strong) {
    color: var(--color-foreground);
    font-weight: 700;
  }

  .post-body :global(em) {
    color: var(--color-foreground);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.375rem 0 0.375rem 1.5rem;
    margin: 1.75rem 0;
    font-style: italic;
    color: var(--color-muted-foreground);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .post-body :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.86em;
    background: color-mix(in oklch, var(--color-accent), transparent 88%);
    color: var(--color-accent);
    padding: 0.125em 0.375em;
    border-radius: 4px;
    border: 1px solid color-mix(in oklch, var(--color-accent), transparent 75%);
  }

  .post-body :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.375rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-foreground);
  }
  .post-body :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Pull quote — add class="pullquote" to a div in MDX */
  .post-body :global(.pullquote) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-card);
    padding: 1.75rem 2rem;
    margin: 2.5rem 0;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    font-style: normal;
  }

  /* Callout — add class="callout" or class="callout warn" to a div in MDX */
  .post-body :global(.callout) {
    background: color-mix(in oklch, var(--color-primary), transparent 85%);
    border: 1px solid color-mix(in oklch, var(--color-primary), transparent 65%);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.375rem;
    margin: 1.75rem 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.875rem;
    align-items: start;
  }
  .post-body :global(.callout .icon) {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 0.875rem;
  }
  .post-body :global(.callout p) {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-primary-foreground);
  }
  .post-body :global(.callout.warn) {
    background: color-mix(in oklch, var(--color-accent), transparent 88%);
    border-color: color-mix(in oklch, var(--color-accent), transparent 65%);
  }
  .post-body :global(.callout.warn .icon) {
    background: var(--color-accent);
    color: var(--color-accent-foreground);
  }
  .post-body :global(.callout.warn p) {
    color: var(--color-foreground);
  }

  /* TOC — rendered from MDX as a div with class="toc" */
  .post-body :global(.toc) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.375rem 1.5rem;
    margin: 0 0 2.5rem;
  }
  .post-body :global(.toc h4) {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    margin: 0 0 0.75rem;
    font-weight: 700;
  }
  .post-body :global(.toc ol) {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: toc;
  }
  .post-body :global(.toc li) {
    counter-increment: toc;
    padding: 0.3125rem 0;
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    display: flex;
    gap: 0.625rem;
  }
  .post-body :global(.toc li::before) {
    content: counter(toc, decimal-leading-zero);
    font-family: monospace;
    color: var(--color-muted-foreground);
    font-size: 0.75rem;
    min-width: 1.5rem;
    opacity: 0.6;
  }
  .post-body :global(.toc li a) {
    border: none;
    color: inherit;
  }
  .post-body :global(.toc li a:hover) {
    color: var(--color-accent);
  }

  /* Tables */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.9em;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    color: var(--color-foreground);
  }
  .post-body :global(th) {
    background: var(--color-surface);
    font-weight: 700;
  }

  /* ── Post nav ───────────────────────────────────────────────── */
  .post-nav-link {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  .post-nav-link:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .post-nav-dir {
    display: block;
    font-family: monospace;
    font-size: 0.68rem;
    color: var(--color-muted-foreground);
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .post-nav-title {
    display: block;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1rem;
    text-transform: uppercase;
    color: var(--color-foreground);
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
</style>
