---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Architecture decisions, prompt anatomy, PRPs, debug stories, and the occasional philosophical detour. Building PocketChomp in public."
>
  <Header />
  <main>
    <section class="border-b-3 border-ink bg-surface">
      <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
        <p class="mb-2 font-display font-bold uppercase tracking-[0.2em] text-accent fs-xs">
          Insights
        </p>
        <h1 class="font-display font-black">Our Blog</h1>
      </div>
    </section>

    <section class="border-b-3 border-ink bg-primary-light">
      <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
        {posts.length === 0 ? (
          <p class="text-center text-ink/60">No posts yet. Check back soon.</p>
        ) : (
          <div class="space-y-8">
            {posts.map((post) => (
              <div class="border-b border-ink pb-8">
                <h2 class="font-display font-black mb-2">{post.data.title}</h2>
                <p class="text-ink/80 mb-4">{post.data.description}</p>
                <a href={`/blog/${post.id}`} class="text-accent hover:underline">Read more</a>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
